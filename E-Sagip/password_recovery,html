<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>E-Sagip – Password Recovery</title>
  <link rel="stylesheet" href="style.css" />
  <link rel="stylesheet" href="style2.css" />
  <link rel="icon" href="Images/628_icon.png" type="image/png" />
</head>
<body class="login-page">

  <!-- Logo -->
  <div class="login-logo">
    <div class="shield-icon">
      <img src="Images/628_logo.png" alt="E-Sagip Logo">
    </div>
    <h1>E-Sagip</h1>
    <p>Barangay 628 BDRRMC Volunteer System</p>
  </div>

  <!-- Back to Login -->
  <div class="back-to-login">
    <a href="index.html">&larr; Back to Login</a>
  </div>

  <!-- Card -->
  <div class="login-card recovery-card">

    <!-- ===== STEP 1: Enter email ===== -->
    <div id="step-email" class="recovery-step">
      <div class="recovery-header">
        <h2>Password Recovery</h2>
        <p>Reset your E-Sagip account password</p>
      </div>

      <div class="recovery-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </div>

      <p class="recovery-instructions">
        Enter your registered email address to begin the recovery process.
      </p>

      <div class="signin-form-group">
        <label for="rec-email">Email Address</label>
        <div class="input-wrap">
          <input type="email" id="rec-email" placeholder="your@email.com" autocomplete="email" />
        </div>
        <div class="field-error hidden" id="email-error">
          No account found with that email address.
        </div>
      </div>

      <button class="btn-signin" onclick="handleFindAccount()">Find My Account</button>
    </div>

    <!-- ===== STEP 2: Security question ===== -->
    <div id="step-security" class="recovery-step hidden">
      <div class="recovery-header">
        <h2>Password Recovery</h2>
        <p>Reset your E-Sagip account password</p>
      </div>

      <div class="recovery-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      </div>

      <p class="recovery-instructions">
        Answer your security question to verify your identity.
      </p>

      <div class="security-question" id="security-question-text">
        What is your mother's maiden name?
      </div>

      <div class="signin-form-group">
        <label for="rec-answer">Your Answer</label>
        <div class="input-wrap">
          <input type="text" id="rec-answer" placeholder="Type your answer..." />
        </div>
        <div class="field-error hidden" id="answer-error">
          That answer doesn't match our records.
        </div>
      </div>

      <button class="btn-signin" onclick="handleVerifyAnswer()">Verify Answer</button>
    </div>

    <!-- ===== STEP 3: New password ===== -->
    <div id="step-reset" class="recovery-step hidden">
      <div class="recovery-header">
        <h2>Password Recovery</h2>
        <p>Reset your E-Sagip account password</p>
      </div>

      <div class="recovery-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>

      <p class="recovery-instructions">
        Create a new password for your account.
      </p>

      <div class="signin-form-group">
        <label for="rec-new-password">New Password</label>
        <div class="input-wrap">
          <input type="password" id="rec-new-password" placeholder="Min. 8 characters" autocomplete="new-password" />
          <button class="toggle-pw" onclick="togglePassword('rec-new-password', this)" type="button" aria-label="Show password">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12S5 5 12 5s11 7 11 7-4 7-11 7S1 12 1 12z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
        <div class="field-error hidden" id="new-password-error">
          Password must be at least 8 characters.
        </div>
      </div>

      <div class="signin-form-group">
        <label for="rec-confirm-password">Confirm Password</label>
        <div class="input-wrap">
          <input type="password" id="rec-confirm-password" placeholder="Repeat password" autocomplete="new-password" />
          <button class="toggle-pw" onclick="togglePassword('rec-confirm-password', this)" type="button" aria-label="Show password">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12S5 5 12 5s11 7 11 7-4 7-11 7S1 12 1 12z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
        <div class="field-error hidden" id="confirm-password-error">
          Passwords do not match.
        </div>
      </div>

      <button class="btn-signin" onclick="handleResetPassword()">Reset Password</button>
    </div>

    <!-- ===== STEP 4: Success ===== -->
    <div id="step-success" class="recovery-step hidden">
      <div class="recovery-header">
        <h2>Password Recovery</h2>
        <p>Reset your E-Sagip account password</p>
      </div>

      <div class="recovery-icon success-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>

      <h3 class="success-title">Password Reset Successful!</h3>
      <p class="recovery-instructions">
        Your password has been updated. You can now log in with your new password.
      </p>

      <a href="index.html" class="btn-signin btn-link">Back to Login</a>
    </div>

  </div>

  <!-- Footer -->
  <p class="login-footer">Sta. Mesa, Manila — BDRRMC Coordination Platform</p>

  <script src="script.js"></script>
</body>
</html>
